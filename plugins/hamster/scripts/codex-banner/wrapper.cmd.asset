@ECHO off
REM ===== HAMSTER-CODEX-BANNER =====
REM Reversible hamster wrapper around the npm-installed codex shim.
REM Prints the banner from "__HAMSTER_BANNER_FILE__" (if present) then delegates
REM to the pristine shim backed up at "__HAMSTER_BACKUP__".
REM Restore: copy that backup back over this file (or run the codex-banner uninstaller).
if exist "__HAMSTER_BANNER_FILE__" (
  echo.
  type "__HAMSTER_BANNER_FILE__"
  echo.
)
call "__HAMSTER_BACKUP__" %*
